APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
STORAGE_DIR=../storage/analyses
MAX_UPLOAD_MB=500
MAX_VIDEO_DURATION_SECONDS=180
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
SILENCE_THRESHOLD_DB=-35
MIN_SILENCE_DURATION=0.8
LONG_SCENE_SECONDS=6.0
VERY_LONG_SCENE_SECONDS=10.0
SHORT_SCENE_SECONDS=0.45
RAPID_CUT_WINDOW_SECONDS=3.0
RAPID_CUT_MIN_COUNT=4
ANALYSIS_RETENTION_HOURS=24

